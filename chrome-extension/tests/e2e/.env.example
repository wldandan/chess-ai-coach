# Chess.com E2E Test Environment Variables
#
# 复制此文件为 .env 并填入真实值
# 注意：.env 文件不应该提交到 git（已添加到 .gitignore）
#
# cp tests/e2e/.env.example tests/e2e/.env

# chess.com 账号
CHESS_COM_USER=your_chess_com_username
CHESS_COM_PASSWORD=your_chess_com_password

# 可选：指定测试的游戏 ID
# 如果不设置，测试会自动获取最近的游戏
# CHESS_COM_GAME_ID=123456789
